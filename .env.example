# =====================================================================
# Nexus Zimbabwe — environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# --- Client (Vite; exposed to the browser bundle) ----------------------
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Server-only (edge-function secrets — DO NOT prefix with VITE_) ----
# Set these in Supabase Dashboard → Edge Functions → Secrets.
#
# SCHOLASTIC_SERVICES_SUPABASE_URL=
# SCHOLASTIC_SERVICES_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=     # used by scholastic-sync to write on behalf of users
# ALLOWED_ORIGINS=               # comma-separated allowlist for CORS
